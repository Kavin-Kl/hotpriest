# Gemini API key (used as the LLM behind Supermemory's proxy)
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supermemory API key (handles memory + proxies to Gemini)
# Get from: https://console.supermemory.ai
VITE_SUPERMEMORY_API_KEY=your_supermemory_api_key_here

# Firebase config - get from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Frontend URL (for OAuth redirects back to app)
FRONTEND_URL=http://localhost:5173
